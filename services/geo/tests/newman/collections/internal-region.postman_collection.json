    {
      "name": "IRG-CR-CRUD-OK — InternalRegionService.Create → 200 Operation{geo-id, metadata}; region materializes (public Get)",
      "description": "class:CRUD | priority:P0",
      "item": [
        {
          "name": "create-region",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{internalBaseUrl}}/geo/v1/internal/regions",
              "host": [
                "{{internalBaseUrl}}"
              ],
              "path": [
                "geo",
                "v1",
                "internal",
                "regions"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"id\": \"qa-reg-crud-{{runId}}\", \"name\": \"QA Region CRUD {{runId}}\", \"countryCode\": \"RU\", \"status\": \"UP\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(200));",
                  "pm.test('Operation envelope (geo-prefixed id + metadata)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.id, 'operation.id ' + JSON.stringify(j)).to.match(/^geo[0-9a-z]+$/);",
                  "  pm.expect(j.metadata, 'operation.metadata').to.be.an('object');",
                  "});",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.metadata && j.metadata.regionId);",
                  "  if (v !== undefined && v !== null) pm.environment.set('irgCrudRegionId', String(v));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "get-region-rgf16",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
