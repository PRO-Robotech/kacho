                "v1",
                "regions",
                "qa-reg-crud-{{runId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// bounded read-your-writes retry публичного GET (async-worker commit window;",
