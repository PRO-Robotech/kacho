            "body": {
              "mode": "raw",
              "raw": "{\"id\": \"qa-anp-reg-{{runId}}\", \"name\": \"QA ANP Region\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(200));",
                  "pm.test('Operation envelope (geo-prefixed id + metadata)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.id, 'operation.id ' + JSON.stringify(j)).to.match(/^geo[0-9a-z]+$/);",
                  "  pm.expect(j.metadata, 'operation.metadata').to.be.an('object');",
                  "});"
                ]
