      "name": "REG-GET-VAL-MALFORMED — GET /geo/v1/regions/{malformed non-slug id} → 400 INVALID_ARGUMENT (no pgx/SQL leak)",
      "description": "class:VAL | class:NEG | priority:P1",
      "item": [
        {
          "name": "get-malformed",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
