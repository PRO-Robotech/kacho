                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(400));",
                  "pm.test('grpc code 3 (INVALID_ARGUMENT)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.code, JSON.stringify(j)).to.eql(3);",
                  "});",
                  "pm.test('field violation on \"page_size\"', () => {",
                  "  const j = pm.response.json();",
                  "  const det = (j.details || []).find(d => (d['@type']||'').includes('BadRequest'));",
                  "  pm.expect(det, 'BadRequest detail').to.be.an('object');",
                  "  const fv = (det.fieldViolations || []).find(v => v.field === 'page_size');",
                  "  pm.expect(fv, 'fieldViolation for page_size').to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
