    {
      "name": "GEO-REG-GT-AUTHZ-AMBIENT-OK — GET /geo/v1/regions as authenticated jwtNoBindings (zero-binding) → 200 (ambient read; project-scope EXEMPT, GEO-1-20)",
      "description": "class:AUTHZ | class:CONF | priority:P1",
      "item": [
        {
          "name": "list-regions-noviewer",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/geo/v1/regions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "geo",
                "v1",
                "regions"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step: bearer from env 'jwtNoBindings'",
                  "const __t = pm.environment.get('jwtNoBindings') || pm.variables.get('jwtNoBindings') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(200));",
                  "pm.test('ambient read: zero-binding principal is NOT denied (no 403)', () => pm.expect(pm.response.code).to.not.eql(403));",
                  "pm.test('regions is an array', () => pm.expect(pm.response.json().regions).to.be.an('array'));"
                ]
              }
            }
          ]
        }
      ]
    },
