{
  "info": {
    "_postman_id": "0752699c-561a-4a47-855a-17cb4e2c25ef",
    "name": "kacho-geo / newman / operation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', (t + r).replace(/[^a-z0-9]/g, '').slice(-10));",
          "}",
          "const __jwt = pm.environment.get('jwtBootstrap') || pm.variables.get('jwtBootstrap') || '';",
          "if (__jwt && !pm.request.headers.has('Authorization')) {",
          "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __jwt});",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "GOP-GET-VAL-MALFORMED — Get operation with malformed id → 400 InvalidArgument 'invalid operation id' (OpsProxy validation)",
      "description": "class:VAL | class:NEG | priority:P1",
      "item": [
        {
          "name": "get-malformed-op",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/garbage-not-an-op-id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "garbage-not-an-op-id"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(400));",
                  "pm.test('grpc code 3 (INVALID_ARGUMENT)', () => {",
                  "  let j; try { j = pm.response.json(); } catch (e) { j = {}; }",
                  "  pm.expect(j.code, JSON.stringify(j)).to.eql(3);",
                  "});",
                  "pm.test('message: invalid operation id', () => pm.expect(String(pm.response.json().message).toLowerCase()).to.include('invalid operation id'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "GEO-IOP-SYNC-DONE-OK — InternalRegionService.Create → Operation{done:true} synchronously (metadata.regionId + response=public Region); unwrap .response (GEO-1-16)",
      "description": "class:STATE | class:CRUD | priority:P0",
      "item": [
        {
          "name": "create-region-for-op",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{internalBaseUrl}}/geo/v1/internal/regions",
              "host": [
                "{{internalBaseUrl}}"
              ],
              "path": [
                "geo",
                "v1",
                "internal",
                "regions"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"id\": \"qa-reg-op-{{runId}}\", \"name\": \"QA Region Op {{runId}}\", \"countryCode\": \"RU\", \"status\": \"UP\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(200));",
                  "pm.test('Operation envelope (geo-prefixed id + metadata)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.id, 'operation.id ' + JSON.stringify(j)).to.match(/^geo[0-9a-z]+$/);",
                  "  pm.expect(j.metadata, 'operation.metadata').to.be.an('object');",
                  "});",
                  "const j = pm.response.json();",
                  "pm.test('Operation done:true synchronously (config-INSERT, no saga)', () => pm.expect(j.done).to.eql(true));",
                  "pm.test('metadata.regionId available immediately', () => pm.expect(j.metadata.regionId).to.eql('qa-reg-op-' + pm.environment.get('runId')));",
                  "pm.test('result.response unwraps to the public Region (id matches)', () => {",
                  "  pm.expect(j.response, JSON.stringify(j)).to.be.an('object');",
                  "  pm.expect(j.response.id).to.eql('qa-reg-op-' + pm.environment.get('runId'));",
                  "});",
                  "pm.test('response is the public Region (openForPlacement true; NO raw status)', () => {",
                  "  pm.expect(j.response.openForPlacement).to.eql(true);",
                  "  pm.expect(j.response).to.not.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "cleanup",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{internalBaseUrl}}/geo/v1/internal/regions/qa-reg-op-{{runId}}",
              "host": [
                "{{internalBaseUrl}}"
              ],
              "path": [
                "geo",
                "v1",
                "internal",
                "regions",
                "qa-reg-op-{{runId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(200));",
                  "pm.test('Operation envelope (geo-prefixed id + metadata)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.id, 'operation.id ' + JSON.stringify(j)).to.match(/^geo[0-9a-z]+$/);",
                  "  pm.expect(j.metadata, 'operation.metadata').to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": []
}