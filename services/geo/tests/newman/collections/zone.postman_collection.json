    {
      "name": "ZON-CR-AUTHZ-ADMIN-NOT-PUBLIC — POST /geo/v1/zones (admin write) as non-admin on public endpoint → rejected, never 200",
      "description": "class:AUTHZ | class:NEG | class:SEC | priority:P0",
      "item": [
        {
          "name": "admin-write-public",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/geo/v1/zones",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "geo",
                "v1",
                "zones"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"id\": \"hacked-zone-{{runId}}\", \"regionId\": \"nonexistent-region-{{runId}}\", \"name\": \"should-not-be-created-{{runId}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step: bearer from env 'jwtNoBindings'",
                  "const __t = pm.environment.get('jwtNoBindings') || pm.variables.get('jwtNoBindings') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin write on public endpoint rejected (401/403/404/501), never 200', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.be.oneOf([401, 403, 404, 501]));"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
