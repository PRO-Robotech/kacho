    {
      "name": "ZON-GET-VAL-MALFORMED — GET /geo/v1/zones/{malformed non-slug id} → 400 INVALID_ARGUMENT (no pgx/SQL leak)",
      "description": "class:VAL | class:NEG | priority:P1",
      "item": [
        {
          "name": "get-malformed",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/geo/v1/zones/9bad-zone",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "geo",
                "v1",
                "zones",
                "9bad-zone"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(400));",
                  "pm.test('grpc code 3 (INVALID_ARGUMENT)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.code, JSON.stringify(j)).to.eql(3);",
                  "});",
                  "pm.test('message mentions invalid/slug zone id (contract tone, tolerant across redesign)', () => pm.expect(pm.response.json().message).to.match(/(lowercase slug|invalid .*zone.*id|zone id)/i));",
                  "pm.test('no pgx/SQL/panic leak in message', () => {",
                  "  const m = String(pm.response.json().message || '').toLowerCase();",
                  "  ['sqlstate','pgx','panic','goroutine'].forEach(t => pm.expect(m, 'leaked ' + t).to.not.include(t));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
