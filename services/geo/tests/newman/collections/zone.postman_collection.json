              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(200));",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.zones && j.zones[0] && j.zones[0].id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('zonId', String(v));",
                  "} catch (e) {}",
                  "pm.test('captured a seeded zone id', () => pm.expect(pm.environment.get('zonId')).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ]
        },
        {
          "name": "get-zone",
