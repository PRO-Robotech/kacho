                  "pm.test('done=true', () => pm.expect(j.done).to.eql(true));",
                  "pm.test('has response', () => pm.expect(j.response).to.be.an('object'));",
                  "pm.test('metadata has networkId', () => pm.expect(j.metadata && j.metadata.networkId).to.match(/^net/));"
                ]
