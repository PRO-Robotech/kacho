            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('grant accepted (200 Operation)', () => pm.expect(pm.response.code, JSON.stringify(j)).to.eql(200));",
                  "pm.test('IAM Operation envelope', () => pm.expect(j.id, JSON.stringify(j)).to.match(/^iop[a-z0-9]+$/));",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('opId', String(v));",
                  "} catch (e) {}",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.metadata && j.metadata.accessBindingId);",
                  "  if (v !== undefined && v !== null) pm.environment.set('rdAuthzAcbId', String(v));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
