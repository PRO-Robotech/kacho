                  "const __t = pm.environment.get('jwtInvitee') || pm.variables.get('jwtInvitee') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}",
                  "// poll-for-propagation counter reset on first entry (request-name-scoped);",
                  "// re-invocations via setNextRequest skip the reset.",
                  "if (pm.environment.get('_poll200_started_get_account_as_granted_invitee') !== pm.info.requestName) {",
                  "  pm.environment.set('_poll200_get_account_as_granted_invitee', '0');",
                  "  pm.environment.set('_poll200_started_get_account_as_granted_invitee', pm.info.requestName);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const _p200c = parseInt(pm.environment.get('_poll200_get_account_as_granted_invitee') || '0', 10);",
                  "const _p200retryCode = [403,404].includes(pm.response.code);",
                  "const _p200retryPred = false;",
                  "if ((_p200retryCode || _p200retryPred) && _p200c < 50) {",
                  "  // access not yet visible at the authz gate (grant→FGA propagation window) — retry.",
                  "  pm.environment.set('_poll200_get_account_as_granted_invitee', String(_p200c + 1));",
                  "  const _p200d = Date.now(); while (Date.now() - _p200d < 500) { /* inter-poll delay ~500ms (Koren #1) */ }",
                  "  pm.execution.setNextRequest(pm.info.requestName);",
                  "  return;",
                  "}",
                  "pm.environment.unset('_poll200_get_account_as_granted_invitee');",
                  "pm.environment.unset('_poll200_started_get_account_as_granted_invitee');",
                  "const j = pm.response.json();",
                  "pm.test('GRANTED-NONOWNER: GET account 200 (was 404 owner-only gate)', () => pm.expect(pm.response.code, JSON.stringify(j)).to.eql(200));",
                  "pm.test('account id matches scope', () => pm.expect(j.id, JSON.stringify(j)).to.eql(pm.environment.get('accountAId')));",
                  "pm.test('owner is NOT the granted invitee (true non-owner read)', () => pm.expect(j.ownerUserId).to.not.eql(pm.environment.get('userINVId')));"
                ]
              }
            }
          ]
        },
