          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
