              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('pre-clean list acceptable', () => pm.expect(pm.response.code).to.be.oneOf([200, 403]));",
                  "pm.environment.unset('rdAuthzDupAcbId');",
                  "if (pm.response.code === 200) {",
                  "  const arr = (pm.response.json() || {}).accessBindings || [];",
                  "  const dup = arr.find(b => b.roleId === 'rol1bda80f2be4d3658e' && b.scopeType === 'iam.account'",
                  "       && b.scopeId === pm.environment.get('accountAId'));",
                  "  if (dup && dup.id) pm.environment.set('rdAuthzDupAcbId', dup.id);",
                  "}",
                  "if (!pm.environment.get('rdAuthzDupAcbId')) { pm.execution.setNextRequest('IAM-RDAUTHZ-ACC-GT-GRANTED-NONOWNER-OK :: grant-view'); }"
                ]
              }
            }
          ]
