    {
      "name": "IAM-RDAUTHZ-ACC-GT-NONGRANTED-DENY — GET account as jwtNoBindings (no v_get grant) → 404 NOT_FOUND (hide existence)",
      "description": "class:AUTHZ | class:NEG | priority:P1",
      "item": [
        {
          "name": "IAM-RDAUTHZ-ACC-GT-NONGRANTED-DENY :: get-account-non-granted",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/iam/v1/accounts/{{accountAId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "iam",
                "v1",
                "accounts",
                "{{accountAId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtPureNoBindings'",
                  "const __t = pm.environment.get('jwtPureNoBindings') || pm.variables.get('jwtPureNoBindings') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('NON-GRANTED: status 404 (hide existence, was 403)', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.eql(404));",
                  "let j; try { j = pm.response.json(); } catch(e) { j = null; }",
                  "pm.test('NON-GRANTED: grpc code 5 (NOT_FOUND, not 7)', () => pm.expect(j && j.code, JSON.stringify(j)).to.eql(5));",
                  "pm.test('NON-GRANTED: no deny_reasons leak', () => pm.expect(JSON.stringify(j || {}).toLowerCase()).to.not.include('deny_reasons'));",
                  "pm.test('NON-GRANTED: no authz violation details leak', () => pm.expect(JSON.stringify(j || {}).toLowerCase()).to.not.include('preconditionfailure'));",
                  "pm.environment.set('rdAuthzDeniedCode', String((j && j.code) !== undefined ? j.code : ''));"
                ]
              }
            }
          ]
        }
      ]
    },
