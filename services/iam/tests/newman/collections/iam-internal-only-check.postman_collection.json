    {
      "name": "IAM-INT-OK-INT-USER-UPSERT — InternalUserService.UpsertFromIdentity on cluster-internal listener → 200, user.id has usr prefix",
      "description": "class:CRUD | class:SEC | priority:P1",
      "item": [
        {
          "name": "IAM-INT-OK-INT-USER-UPSERT :: upsert-from-identity-on-internal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/iam/v1/internal/users:upsertFromIdentity",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "iam",
                "v1",
                "internal",
                "users:upsertFromIdentity"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"externalId\": \"zit-positive-{{runId}}\", \"email\": \"positive-{{runId}}@kacho.local\", \"displayName\": \"Positive Control {{runId}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}",
                  "// internal-only POSITIVE control: send this request to the api-gateway",
                  "// cluster-internal REST listener (Internal* paths live ONLY there).",
                  "const intBase = pm.environment.get('internalBaseUrl') || pm.variables.get('internalBaseUrl') || '';",
                  "if (!intBase) {",
                  "  console.warn('internalBaseUrl not set in env — skipping internal-mux positive control for this step.');",
                  "  postman.setNextRequest(null);",
                  "} else {",
                  "  pm.request.url = intBase + '/iam/v1/internal/users:upsertFromIdentity';",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('INT-UPSERT: user id has usr prefix', () => {",
                  "  const j = pm.response.json();",
                  "  // UpsertFromIdentity returns an Operation with metadata.userId.",
                  "  // Fallbacks: j.user.id (direct User), j.id (older API).",
                  "  const uid = (j.metadata && j.metadata.userId) || (j.user && j.user.id) || j.id;",
                  "  pm.expect(uid, 'user id must start with usr').to.match(/^usr[a-z0-9]+$/);",
                  "});",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('createdInternalUserOpId', String(v));",
                  "} catch (e) {}",
                  "try {",
                  "  const j = pm.response.json();",
