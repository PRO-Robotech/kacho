                  "  pm.expect(j.accounts, 'accounts field').to.be.an('array');",
                  "});",
                  "pm.test('WhoAmI-NOB: systemAdmin = false (regular user)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.systemAdmin, 'NOB must not be system_admin').to.eql(false);",
                  "});"
                ]
