              "raw": "{\"subjectId\": \"project:prj-secc-{{runId}}\", \"relation\": \"parent\", \"object\": \"vpc_network:enpsecc{{runId}}\", \"traceId\": \"secc-a01-{{runId}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
