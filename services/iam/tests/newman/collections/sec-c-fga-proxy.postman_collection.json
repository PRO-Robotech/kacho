      "name": "SEC-C-A-09-NEG-EXT-INTERNAL-ONLY — RegisterResource on external TLS endpoint → 404 (internal-only, ban #6)",
      "description": "class:NEG | class:SEC | priority:P0",
      "item": [
        {
          "name": "SEC-C-A-09-NEG-EXT-INTERNAL-ONLY :: register-on-external",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/iam/v1/internal:registerResource",
              "host": [
                "{{baseUrl}}"
              ],
