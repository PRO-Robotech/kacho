{
  "info": {
    "_postman_id": "3322122b-01f3-573b-b651-13b8c94444cc",
    "name": "kacho-iam / newman / iam-flat-authz-vbc",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  // runId формат: только [a-z0-9], без точки, начинается с буквы — чтобы проходить compute name regex",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', ('r' + t + r).replace(/[^a-z0-9]/g, '').slice(0, 11));",
          "}",
          "pm.environment.set('_suiteFolderId', pm.environment.get('existingProjectId'));",
          "pm.environment.set('_suiteFolderCrossId', pm.environment.get('existingProjectCrossId'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "IAM-VBC-ACB-LOWERCASE-SUBJECT-DERIVE — AccessBinding.Create with lowercase subject type (`user`) + usr-prefixed id → derive → Operation(iop) done",
      "description": "class:VAL | class:CRUD | priority:P1",
      "item": [
        {
          "name": "IAM-VBC-ACB-LOWERCASE-SUBJECT-DERIVE :: pre-clean-revoke",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/iam/v1/accessBindings:listBySubject?subjectType=user&subjectId={{userNOBId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "iam",
                "v1",
                "accessBindings:listBySubject?subjectType=user&subjectId={{userNOBId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('pre-clean list acceptable', () => pm.expect(pm.response.code).to.be.oneOf([200, 403]));",
                  "pm.environment.unset('vbcDupAcbId');",
                  "if (pm.response.code === 200) {",
                  "  const arr = (pm.response.json() || {}).accessBindings || [];",
                  "  const dup = arr.find(b => b.roleId === 'rol1bda80f2be4d3658e' && b.resourceType === 'account'",
                  "       && b.resourceId === pm.environment.get('accountAId'));",
                  "  if (dup && dup.id) pm.environment.set('vbcDupAcbId', dup.id);",
                  "}",
                  "if (!pm.environment.get('vbcDupAcbId')) { pm.execution.setNextRequest('IAM-VBC-ACB-LOWERCASE-SUBJECT-DERIVE :: create-derive'); }"
                ]
              }
            }
          ]
        },
        {
          "name": "IAM-VBC-ACB-LOWERCASE-SUBJECT-DERIVE :: del-dup",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/iam/v1/accessBindings/{{vbcDupAcbId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "iam",
                "v1",
                "accessBindings",
                "{{vbcDupAcbId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('del-dup acceptable', () => pm.expect(pm.response.code).to.be.oneOf([200, 404, 403]));",
                  "pm.environment.unset('vbcDelOpId');",
                  "if (pm.response.code === 200) {",
                  "  const dj = pm.response.json() || {};",
                  "  if (dj.id) pm.environment.set('vbcDelOpId', dj.id);",
                  "}",
                  "if (!pm.environment.get('vbcDelOpId')) { pm.execution.setNextRequest('IAM-VBC-ACB-LOWERCASE-SUBJECT-DERIVE :: create-derive'); }"
                ]
              }
            }
          ]
        },
        {
          "name": "IAM-VBC-ACB-LOWERCASE-SUBJECT-DERIVE :: await-del-dup",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{vbcDelOpId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{vbcDelOpId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}",
                  "if (pm.environment.get('_vbcDelStarted') !== pm.info.requestName) {",
                  "  pm.environment.set('_vbcDelCount', '0');",
                  "  pm.environment.set('_vbcDelStarted', pm.info.requestName);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('await-del-dup status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "const pc = parseInt(pm.environment.get('_vbcDelCount') || '0', 10);",
                  "if (!j.done && pc < 30) {",
                  "  pm.environment.set('_vbcDelCount', String(pc + 1));",
                  "  pm.execution.setNextRequest(pm.info.requestName);",
                  "  return;",
                  "}",
                  "pm.environment.unset('_vbcDelCount');",
                  "pm.environment.unset('_vbcDelStarted');",
                  "pm.test('dup-revoke operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "IAM-VBC-ACB-LOWERCASE-SUBJECT-DERIVE :: create-derive",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/iam/v1/accessBindings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "iam",
                "v1",
                "accessBindings"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"subjects\": [{\"type\": \"user\", \"id\": \"{{userNOBId}}\"}], \"roleId\": \"rol1bda80f2be4d3658e\", \"scopeRef\": {\"tier\": \"ACCOUNT\", \"id\": \"{{accountAId}}\"}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('lowercase subject derive accepted (200)', () => pm.expect(pm.response.code, JSON.stringify(j)).to.eql(200));",
                  "pm.test('IAM Operation envelope returned', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.id, 'operation.id must start with iop').to.match(/^iop[a-z0-9]+$/);",
                  "  pm.expect(j.done, 'operation.done present').to.be.a('boolean');",
                  "});",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('opId', String(v));",
                  "} catch (e) {}",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.metadata && j.metadata.accessBindingId);",
                  "  if (v !== undefined && v !== null) pm.environment.set('vbcAcbId', String(v));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "IAM-VBC-ACB-LOWERCASE-SUBJECT-DERIVE :: poll-op",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}",
                  "// poll-counter reset on first entry (request-name-scoped flag);",
                  "// re-invocations via setNextRequest skip the reset.",
                  "if (pm.environment.get('_pollStarted') !== pm.info.requestName) {",
                  "  pm.environment.set('_pollCount', '0');",
                  "  pm.environment.set('_pollStarted', pm.info.requestName);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('poll status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "const pc = parseInt(pm.environment.get('_pollCount') || '0', 10);",
                  "if (!j.done && pc < 50) {",
                  "  pm.environment.set('_pollCount', String(pc + 1));",
                  "  const _pd = Date.now(); while (Date.now() - _pd < 500) { /* inter-poll delay ~500ms (Koren #1) */ }",
                  "  pm.execution.setNextRequest(pm.info.requestName);",
                  "  return;",
                  "}",
                  "pm.environment.unset('_pollCount');",
                  "pm.environment.unset('_pollStarted');",
                  "pm.test('operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));",
                  "if (j.error) pm.environment.set('lastOpError', JSON.stringify(j.error));",
                  "else pm.environment.unset('lastOpError');",
                  "if (j.response) pm.environment.set('lastOpResponse', JSON.stringify(j.response));"
                ]
              }
            }
          ]
        },
        {
          "name": "IAM-VBC-ACB-LOWERCASE-SUBJECT-DERIVE :: op-success",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('derive-create Operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));",
                  "pm.test('subject derived (no INVALID_ARGUMENT — lowercase type resolved)', () => {",
                  "  const code = j.error && j.error.code;",
                  "  pm.expect(code, 'derive must NOT be rejected as INVALID_ARGUMENT: ' + JSON.stringify(j.error)).to.not.eql(3);",
                  "});"
                ]
              }
            }
          ]
        },
