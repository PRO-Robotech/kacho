{
  "info": {
    "_postman_id": "07b15994-3f09-5411-aea2-5da8374e7318",
    "name": "kacho-iam / newman / iam-rbac-rules-labels",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  // runId формат: только [a-z0-9], без точки, начинается с буквы — чтобы проходить compute name regex",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', ('r' + t + r).replace(/[^a-z0-9]/g, '').slice(0, 11));",
          "}",
          "pm.environment.set('_suiteFolderId', pm.environment.get('existingProjectId'));",
          "pm.environment.set('_suiteFolderCrossId', pm.environment.get('existingProjectCrossId'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "RBACLBL-FED-ACCEPTED — ARM_LABELS rule on fed type compute.instance → Role.Create accepted (C-22 role-side)",
      "description": "class:RBAC | class:RULES | class:LABELS | class:HAPPY | priority:P0",
      "item": [
        {
          "name": "RBACLBL-FED-ACCEPTED :: create-label-role-fed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/iam/v1/roles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "iam",
                "v1",
                "roles"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"accountId\": \"{{accountAId}}\", \"name\": \"rbac_lbl_fed_{{runId}}\", \"description\": \"newman ARM_LABELS fed-type probe role\", \"rules\": [{\"module\": \"compute\", \"resources\": [\"instance\"], \"verbs\": [\"get\", \"create\"], \"matchLabels\": {\"env\": \"prod\"}}]}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('_opLblFed', String(v));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "RBACLBL-FED-ACCEPTED :: poll-label-role-fed",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{_opLblFed}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{_opLblFed}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'jwtAccountAdminA'",
                  "const __t = pm.environment.get('jwtAccountAdminA') || pm.variables.get('jwtAccountAdminA') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (pm.environment.get('_pollStarted') !== pm.info.requestName) { pm.environment.set('_pollCount', '0'); pm.environment.set('_pollStarted', pm.info.requestName); }",
                  "const pc = parseInt(pm.environment.get('_pollCount') || '0', 10);",
                  "if (!j.done && pc < 30) {",
                  "  pm.environment.set('_pollCount', String(pc + 1));",
                  "  pm.execution.setNextRequest(pm.info.requestName);",
                  "  return;",
                  "}",
                  "pm.environment.unset('_pollCount');",
                  "pm.environment.unset('_pollStarted');",
                  "",
                  "pm.test('operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));",
                  "pm.test('operation no error', () => pm.expect(j.error, JSON.stringify(j)).to.not.exist);"
                ]
              }
            }
          ]
        }
      ]
    },
