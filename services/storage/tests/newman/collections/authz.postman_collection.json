{
  "info": {
    "_postman_id": "84d673b1-fe69-4ff4-86cd-70240ddf3102",
    "name": "kacho-storage / newman / authz",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  // runId формат: только [a-z0-9], без точки, начинается с буквы — чтобы проходить compute name regex",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', ('r' + t + r).replace(/[^a-z0-9]/g, '').slice(0, 11));",
          "}",
          "pm.environment.set('_suiteFolderId', pm.environment.get('existingProjectId'));",
          "pm.environment.set('_suiteFolderCrossId', pm.environment.get('existingProjectCrossId'));",
          "const __defaultJwt = pm.environment.get('jwtBootstrap') || pm.variables.get('jwtBootstrap') || '';",
          "if (__defaultJwt && !pm.request.headers.has('Authorization')) {",
          "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __defaultJwt});",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "AUTHZ-VOL-LIST-CROSS-DENY — [INV-10] alice List volumes projectId=projectB1 (нет viewer) → 403 PERMISSION_DENIED (scope {project,project_id})",
      "description": "class:AUTHZ | class:SEC | class:NEG | priority:P0",
      "item": [
        {
          "name": "list-cross",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/storage/v1/volumes?projectId={{projectB1Id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "storage",
                "v1",
                "volumes?projectId={{projectB1Id}}"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// KAC-122 authz-deny: bearer from env 'jwtProjectAdminA1'",
                  "const __t = pm.environment.get('jwtProjectAdminA1') || pm.variables.get('jwtProjectAdminA1') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[AUTHZ-VOL-LIST-CROSS-DENY] DENY: status 403', () => pm.expect(pm.response.code, JSON.stringify(pm.response.text())).to.equal(403));",
                  "let j; try { j = pm.response.json(); } catch(e) { j = null; }",
                  "pm.test('[AUTHZ-VOL-LIST-CROSS-DENY] DENY: grpc code 7 (PERMISSION_DENIED)', () => pm.expect(j && j.code, JSON.stringify(j)).to.equal(7));",
                  "pm.test('[AUTHZ-VOL-LIST-CROSS-DENY] DENY: message contains permission denied', () => pm.expect((j && j.message || '').toLowerCase()).to.contain('permission denied'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "AUTHZ-VOL-LIST-OWN-ALLOW-NOLEAK — [INV-10] alice List volumes projectId=projectA1 (есть viewer) → not 403; result содержит ТОЛЬКО projectA1 (нет кросс-проектной утечки)",
      "description": "class:AUTHZ | class:SEC | class:POS | priority:P0",
      "item": [
        {
          "name": "list-own",
          "request": {
            "method": "GET",
