{
  "info": {
    "_postman_id": "2dd9a5c8-2ecd-4fa1-8ee5-418ff17e93b8",
    "name": "kacho-storage / newman / operation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  // runId формат: только [a-z0-9], без точки, начинается с буквы — чтобы проходить compute name regex",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', ('r' + t + r).replace(/[^a-z0-9]/g, '').slice(0, 11));",
          "}",
          "pm.environment.set('_suiteFolderId', pm.environment.get('existingProjectId'));",
          "pm.environment.set('_suiteFolderCrossId', pm.environment.get('existingProjectCrossId'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "OP-GET-CRUD-OK — Get done-operation (после Volume.Create) → done=true, response, metadata.volumeId, id prefix sop",
      "description": "class:CRUD | class:CONF | priority:P1",
      "item": [
        {
          "name": "create-trigger",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/storage/v1/volumes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "storage",
                "v1",
                "volumes"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"projectId\": \"{{_suiteFolderId}}\", \"name\": \"vol-op-get-{{runId}}\", \"zoneId\": \"{{existingZoneId}}\", \"diskTypeId\": \"{{existingDiskTypeId}}\", \"sizeBytes\": 10737418240}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('opId', String(v));",
                  "} catch (e) {}",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.metadata && j.metadata.volumeId);",
                  "  if (v !== undefined && v !== null) pm.environment.set('volumeId', String(v));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "poll-op",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('poll status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "const pc = parseInt(pm.environment.get('_pollCount') || '0', 10);",
                  "if (!j.done && pc < 30) {",
                  "  pm.environment.set('_pollCount', String(pc + 1));",
                  "  const _pd = Date.now(); while (Date.now() - _pd < 500) { /* inter-poll delay ~500ms (Koren #1) */ }",
                  "  pm.execution.setNextRequest(pm.info.requestName);",
                  "  return;",
                  "}",
                  "pm.environment.unset('_pollCount');",
                  "pm.test('operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));",
                  "if (j.error) pm.environment.set('lastOpError', JSON.stringify(j.error));",
                  "else pm.environment.unset('lastOpError');",
                  "if (j.response) pm.environment.set('lastOpResponse', JSON.stringify(j.response));"
                ]
              }
            }
          ]
        },
        {
          "name": "get-op",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "pm.test('id matches & sop prefix', () => { pm.expect(j.id).to.eql(pm.environment.get('opId')); pm.expect(j.id).to.match(/^sop/); });",
                  "pm.test('done=true', () => pm.expect(j.done).to.eql(true));",
                  "pm.test('has response (no error)', () => { pm.expect(j.response).to.be.an('object'); pm.expect(j.error).to.be.oneOf([undefined, null]); });",
                  "pm.test('metadata.volumeId prefix vol', () => pm.expect(j.metadata && j.metadata.volumeId).to.match(/^vol/));",
                  "pm.test('createdAt present', () => pm.expect(j.createdAt).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "cleanup",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/storage/v1/volumes/{{volumeId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "storage",
                "v1",
                "volumes",
                "{{volumeId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('opId', String(v));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "poll-op",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('poll status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "const pc = parseInt(pm.environment.get('_pollCount') || '0', 10);",
                  "if (!j.done && pc < 30) {",
                  "  pm.environment.set('_pollCount', String(pc + 1));",
                  "  const _pd = Date.now(); while (Date.now() - _pd < 500) { /* inter-poll delay ~500ms (Koren #1) */ }",
                  "  pm.execution.setNextRequest(pm.info.requestName);",
                  "  return;",
                  "}",
                  "pm.environment.unset('_pollCount');",
                  "pm.test('operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));",
                  "if (j.error) pm.environment.set('lastOpError', JSON.stringify(j.error));",
                  "else pm.environment.unset('lastOpError');",
                  "if (j.response) pm.environment.set('lastOpResponse', JSON.stringify(j.response));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "OP-GET-NEG-NOTFOUND-VALID-PREFIX — Get well-formed-но-нет sop-opId → 404 NOT_FOUND",
      "description": "class:NEG | priority:P1",
      "item": [
        {
          "name": "get-nx",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{garbageStorageOpId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{garbageStorageOpId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 404', () => pm.expect(pm.response.code).to.eql(404));",
                  "pm.test('grpc code 5 (NOT_FOUND)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.code, JSON.stringify(j)).to.eql(5);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "OP-GET-NEG-UNKNOWN-PREFIX — Get opId без known 3-char prefix → 400 INVALID_ARGUMENT 'prefix' (OpsProxy отвергает неизвестный префикс)",
      "description": "class:NEG | priority:P1",
      "item": [
        {
          "name": "get-garbage-prefix",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{garbageId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{garbageId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.expect(pm.response.code).to.eql(400));",
                  "pm.test('grpc code 3 (INVALID_ARGUMENT)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.code, JSON.stringify(j)).to.eql(3);",
                  "});",
                  "pm.test('mentions prefix', () => pm.expect((pm.response.json().message || '').toLowerCase()).to.include('prefix'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
