{
  "info": {
    "_postman_id": "159d6ab7-3336-461b-b2f0-3e3b75f93f98",
    "name": "kacho-storage / newman / disk-type",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  // runId формат: только [a-z0-9], без точки, начинается с буквы — чтобы проходить compute name regex",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', ('r' + t + r).replace(/[^a-z0-9]/g, '').slice(0, 11));",
          "}",
          "pm.environment.set('_suiteFolderId', pm.environment.get('existingProjectId'));",
          "pm.environment.set('_suiteFolderCrossId', pm.environment.get('existingProjectCrossId'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "DT-LST-CRUD-OK — List diskTypes → ≥5 seeded slug'ов (block-standard/-balanced/-fast/-single/-io-max), у каждого performanceTier + zoneIds array",
      "description": "class:CRUD | priority:P1",
      "item": [
        {
          "name": "list",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/storage/v1/diskTypes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "storage",
                "v1",
                "diskTypes"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "pm.test('diskTypes is array', () => pm.expect(j.diskTypes || []).to.be.an('array'));",
                  "const ids = (j.diskTypes || []).map(x => x.id);",
                  "pm.test('at least 5 seeded types', () => pm.expect(ids.length).to.be.at.least(5));",
                  "['block-standard','block-balanced','block-fast','block-single','block-io-max'].forEach(s => pm.test('contains ' + s, () => pm.expect(ids).to.include(s)));",
                  "pm.test('each has performanceTier + zoneIds array', () => (j.diskTypes || []).forEach(t => { pm.expect(t.performanceTier, t.id).to.be.a('string'); pm.expect(t.zoneIds || [], t.id).to.be.an('array'); }));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "DT-GET-CRUD-OK — Get block-balanced → id=block-balanced, performanceTier=balanced, zoneIds array",
      "description": "class:CRUD | class:CONF | priority:P1",
