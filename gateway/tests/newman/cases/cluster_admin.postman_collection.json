                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "pm.test('ListAdmins includes newly-granted U3', () => {",
                  "  const j = pm.response.json();",
                  "  const u3 = pm.environment.get('userOrdinaryId');",
