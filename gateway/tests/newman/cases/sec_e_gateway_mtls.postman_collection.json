    {
      "name": "SEC-E-GATEWAY-MTLS-BAN6-ADDRESSPOOL — GET /vpc/v1/addressPools on external TLS endpoint → not exposed (ban #6, mTLS profile)",
      "description": "class:NEG | class:SEC | priority:P0",
      "item": [
        {
          "name": "addresspool-on-external-tls",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/vpc/v1/addressPools",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vpc",
                "v1",
                "addressPools"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// per-step auth: bearer from env 'tokenAlice'",
                  "const __t = pm.environment.get('tokenAlice') || pm.variables.get('tokenAlice') || '';",
                  "if (__t) {",
                  "  pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + __t});",
                  "} else {",
                  "  pm.request.headers.remove('Authorization');",
                  "}",
                  "const extBase = pm.environment.get('externalBaseUrl') || pm.variables.get('externalBaseUrl') || '';",
                  "if (!extBase) {",
                  "  console.warn('externalBaseUrl not set — skipping ban#6 external-AddressPool check.');",
                  "  postman.setNextRequest(null);",
                  "} else {",
                  "  pm.request.url = extBase + '/vpc/v1/addressPools';",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('EXT-TLS: AddressPool (Internal) not exposed on external endpoint', () => {",
                  "  const code = pm.response.code;",
                  "  if (code === undefined) { return; }  // DNS / conn error = not exposed = PASS",
                  "  pm.expect(code, 'CRITICAL: Internal AddressPool exposed on external TLS!').to.eql(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
